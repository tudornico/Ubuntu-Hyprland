{
  "layer": "top",
  "position": "top",
  "height": 40,
  "spacing": 4,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["hyprland/window", "custom/music"],
  "modules-right": ["memory", "cpu", "pulseaudio", "clock", "custom/weather"],
  "hyprland/workspaces": { "format": "{id}" },
  "hyprland/window": { "max-length": 50 },
  "clock": { "format": "{:%H:%M}", "tooltip-format": "{:%A, %d %B %Y}" },
  "pulseaudio": { "format": "♥ {volume}%" },
  "memory": { "format": "⬆ {used:0.1f}G" },
  "cpu": { "format": " {usage}%", "interval": 2 },
  
"custom/music": {
    "exec": "stdbuf -oL /home/tudor/.config/waybar/mediaplayer.sh",
    "return-type": "json",
    "interval": "once",
    "restart-interval": 5,
    "max-length": 60
},

  "custom/weather": {
    "exec": "curl -s 'wttr.in/Cluj-Napoca?format=1'",
    "interval": 1800,
    "max-length": 20
  }
}