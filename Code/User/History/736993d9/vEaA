[general]
bars = 16
autosens = 1
overshoot = 0
framerate = 40

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7
ascii_data_separator = 0
ascii_data_newline = 1

[smoothing]
# 98 is very "lazy" and liquid—perfect for high-pitched stability
integral = 98
monstercat = 1
monstercat_factor = 2.0
# Lower gravity (30) keeps the high notes from "crashing" down
gravity = 30
# This acts as a "gate" to keep the tiny sounds visible
noise_reduction = 0.05